<Window x:Class="Rewards_Fast2._0.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rewards Fast — Конструктор наградных материалов" 
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>



        <!-- Основная горизонтальная панель (левая, центр, правая) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- ЛЕВАЯ ПАНЕЛЬ: Блоки + Свойства -->
            <Border Grid.Column="0" BorderBrush="LightGray" BorderThickness="1" CornerRadius="8" Margin="0,0,10,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">

                        <TextBlock Text="БЛОКИ" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                        <ScrollViewer Height="200" Margin="0,0,0,10">
                            <ListBox x:Name="BlocksListBox" DisplayMemberPath="Text" SelectionChanged="BlocksListBox_SelectionChanged"/>
                        </ScrollViewer>

                        <Button x:Name="AddBlockButton" Content="+ Добавить блок" Click="AddBlockButton_Click" Margin="0,0,0,15"/>

                        <Button x:Name="AiSuggestButton" Content="✨ ИИ подскажет" Click="AiSuggestButton_Click" Margin="0,0,0,20"/>

                        <TextBlock Text="⚙️ СВОЙСТВА" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                        <TextBlock Text="Текст:" Margin="0,0,0,3"/>
                        <TextBox x:Name="TextPropertyBox" TextChanged="TextPropertyBox_TextChanged" Margin="0,0,0,10"/>

                        <TextBlock Text="Шрифт:" Margin="0,0,0,3"/>
                        <ComboBox x:Name="FontFamilyBox" SelectionChanged="FontProperty_Changed" Margin="0,0,0,10"/>

                        <TextBlock Text="Размер:" Margin="0,0,0,3"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBox x:Name="FontSizeBox" Width="60" TextChanged="FontProperty_Changed"/>
                            <Button x:Name="FontSizeUp" Content="▲" Width="30" Click="FontSizeUp_Click" Margin="5,0,2,0"/>
                            <Button x:Name="FontSizeDown" Content="▼" Width="30" Click="FontSizeDown_Click"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <ToggleButton x:Name="BoldToggle" Content="B" Width="40" Margin="0,0,5,0" Click="FontStyle_Changed"/>
                            <ToggleButton x:Name="ItalicToggle" Content="I" Width="40" Click="FontStyle_Changed"/>
                        </StackPanel>

                        <TextBlock Text="Положение:" Margin="0,0,0,3"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="X:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBox Grid.Column="1" x:Name="PositionXBox" TextChanged="Position_Changed"/>
                            <TextBlock Grid.Column="2" Text="Y:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                            <TextBox Grid.Column="3" x:Name="PositionYBox" TextChanged="Position_Changed"/>
                        </Grid>

                        <Button x:Name="DeleteBlockButton" Content="🗑️ Удалить блок" Click="DeleteBlockButton_Click" 
                    Margin="0,5,0,0" Background="LightCoral"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ЦЕНТРАЛЬНАЯ ПАНЕЛЬ: Превью -->
            <Border Grid.Column="1" BorderBrush="LightGray" BorderThickness="1" CornerRadius="8" Margin="0,0,10,0">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Border Background="White" BorderBrush="Gray" BorderThickness="2" Padding="5">
                        <Canvas x:Name="PreviewCanvas" Width="800" Height="600" 
                                Background="LightGray" AllowDrop="True">
                            <TextBlock Text="🖼️ Здесь будет превью грамоты" 
                                       Canvas.Left="300" Canvas.Top="280" FontSize="16" Foreground="Gray"/>
                        </Canvas>
                    </Border>
                </ScrollViewer>
            </Border>

            <!-- ПРАВАЯ ПАНЕЛЬ: Фон и шаблон -->
            <Border Grid.Column="2" BorderBrush="LightGray" BorderThickness="1" CornerRadius="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">

                        <TextBlock Text="ФОН НАГРАДНОГО МАТЕРИАЛА" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                        <!-- Универсальная зона Drag-and-drop -->
                        <Border BorderBrush="Gray" BorderThickness="2" CornerRadius="8" 
                    Background="LightGray" Height="120" Margin="0,0,0,10"
                    AllowDrop="True" DragOver="UniversalDragOver" Drop="UniversalDrop">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="📸 Перетащите сюда:" TextAlignment="Center" Foreground="Gray"/>
                                <TextBlock Text="изображение (PNG, JPG)" TextAlignment="Center" Foreground="Gray" FontSize="11"/>
                                <TextBlock Text="или" TextAlignment="Center" Foreground="Gray"/>
                                <TextBlock Text="шаблон (JSON)" TextAlignment="Center" Foreground="Gray" FontSize="11"/>
                                <TextBlock Text="или" TextAlignment="Center" Foreground="Gray"/>
                                <Button x:Name="SelectFileButton" Content="Выбрать файл" 
        Margin="10,5,10,5" Click="SelectFileButton_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Миниатюра фона -->
                        <Image x:Name="BackgroundThumbnail" Height="80" Stretch="Uniform" Margin="0,0,0,10"/>

                        <!-- Библиотека фонов -->
                        <TextBlock Text="БИБЛИОТЕКА ФОНОВ" FontWeight="Bold" FontSize="12" Margin="0,10,0,5"/>
                        <ScrollViewer Height="150" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="BackgroundLibraryItems">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" 
                                    Margin="5" Cursor="Hand" MouseLeftButtonUp="BackgroundThumbnail_Click">
                                            <Image Source="{Binding Thumbnail}" Width="80" Height="80" Stretch="Uniform"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- НИЖНЯЯ ПАНЕЛЬ: Данные + Генерация -->
        <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="12" Margin="0,10,0,0">
            <StackPanel Margin="15">

                <TextBlock Text="Данные для генерации" FontWeight="SemiBold" FontSize="14" 
                           Foreground="#2C3E50" Margin="0,0,0,12"/>

                <!-- Drag-and-drop зона -->
                <Border BorderBrush="#B0BEC5" BorderThickness="1.5" CornerRadius="10" 
                        Background="#F8F9FA" Padding="12" Margin="0,0,0,12"
                        AllowDrop="True" DragOver="ExcelDragOver" Drop="ExcelDrop">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="📂" FontSize="20" Margin="0,0,8,0"/>
                        <TextBlock Text="Перетащите Excel/CSV файл сюда или" VerticalAlignment="Center" Foreground="#5D6D7E"/>
                        <Button x:Name="SelectExcelButton" Content="Выбрать файл" 
                                Margin="20,0,0,0" Click="SelectExcelButton_Click"/>
                    </StackPanel>
                </Border>

                <!-- Падеж -->
                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Падеж для ФИО:" VerticalAlignment="Center" Margin="0,0,20,0" FontWeight="Medium"/>
                        <RadioButton x:Name="NominativeCase" Content="Именительный (Иванов Иван Иванович)" 
                                     GroupName="Case" IsChecked="True" Checked="Case_Changed" Margin="0,0,20,0"/>
                        <RadioButton x:Name="DativeCase" Content="Дательный (Иванову Ивану Ивановичу)" 
                                     GroupName="Case" Checked="Case_Changed"/>
                    </StackPanel>
                </Border>

                <!-- Таблица -->
                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="10" Margin="0,0,0,12">
                    <DataGrid x:Name="PersonsGrid" AutoGenerateColumns="False" Height="160" 
                              CanUserAddRows="False" IsReadOnly="True" BorderThickness="0"
                              RowHeight="35" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Исходное ФИО" Binding="{Binding FullName}" Width="*"/>
                            <DataGridTextColumn Header="ФИО в выбранном падеже" Binding="{Binding DisplayName}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Настройки сохранения -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Папка для результатов:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" x:Name="OutputFolderBox" Margin="0,0,10,0"/>
                    <Button Grid.Column="2" x:Name="BrowseFolderButton" Content="Обзор" 
                            Click="BrowseFolderButton_Click" Margin="0,0,10,0" Width="70"/>
                    <Button Grid.Column="3" x:Name="OpenFolderButton" Content="📁" 
                            Click="OpenOutputFolderButton_Click" Width="40" ToolTip="Открыть папку с результатами"/>
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Формат изображений:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox Grid.Column="1" x:Name="ImageFormatBox" Width="100" HorizontalAlignment="Left" SelectedIndex="0">
                        <ComboBoxItem Content="PNG"/>
                        <ComboBoxItem Content="JPG"/>
                    </ComboBox>
                </Grid>

                <CheckBox x:Name="AutoSaveTemplateCheckBox" 
                          Content="Автоматически сохранять копию шаблона рядом с результатами" 
                          IsChecked="True" Margin="0,0,0,12" Foreground="#2C3E50"/>

                <!-- Кнопки действий -->
                <Grid Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" x:Name="SaveTemplateButton" Content="💾 Сохранить только шаблон" 
                            Click="SaveTemplateButton_Click" Width="180" Margin="0,0,15,0"/>

                    <Button Grid.Column="2" x:Name="GenerateButton" Content="✨ Сгенерировать пачку" 
                            Click="GenerateButton_Click" Width="200" Background="#27AE60" Foreground="White" FontWeight="SemiBold"/>
                </Grid>

            </StackPanel>
        </Border>
    </Grid>
</Window>